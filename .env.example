# App
VITE_APP_ENV=
VITE_API_BASE_URL=
PUBLIC_APP_URL=https://holy-domain-fortune-telling.vercel.app

# Supabase public client only
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server only - do not expose to client
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Internal AI providers - server only (NEVER expose to client)
ANTHROPIC_API_KEY=
CLAUDE_MODEL_PREMIUM=claude-sonnet-5

GEMINI_API_KEY=
GEMINI_MODEL_FREE=gemini-3.1-flash-lite

FREE_ASTRO_API_KEY=

# Server plan limits
PLAN_FREE_TAROT_DAILY_LIMIT=1
PLAN_PRO_TAROT_MONTHLY_LIMIT=30
PLAN_MASTER_TAROT_MONTHLY_LIMIT=50

# PayPal (server only for secret)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENV=sandbox

# PayPal Billing Plan IDs start with P-. Leave blank to use the fixed-link
# fallback, which will require email/manual reconciliation when PayPal cannot
# return the app checkout token.
PAYPAL_PLAN_99_ID=
PAYPAL_PLAN_99_PRICE_TWD=99
PAYPAL_PLAN_99_LINK=https://www.paypal.com/ncp/payment/WXRQLYEH8TSFJ

PAYPAL_PLAN_299_ID=
PAYPAL_PLAN_299_PRICE_TWD=299
PAYPAL_PLAN_299_LINK=https://www.paypal.com/ncp/payment/NSQVJ9TZC3C88

# Admin
ADMIN_EMAILS=erin20080306@gmail.com
ADMIN_DEBUG_AI_PROVIDER_VISIBLE=false

# Fortune feature flags
FORTUNE_FEATURE_ENABLED=true
FORTUNE_TIMEZONE=Asia/Taipei

FORTUNE_GEMINI_FREE_MODE_ENABLED=false
FORTUNE_CLAUDE_PREMIUM_ENABLED=false
FORTUNE_PREMIUM_ENABLED=false

# PayPal platform visibility (server truth; client mirrors via VITE_ below)
PAYPAL_CHECKOUT_ENABLED=false
PAYPAL_WEB_CHECKOUT_ONLY=true
IOS_HIDE_EXTERNAL_PAYPAL_LINKS=true
ANDROID_HIDE_EXTERNAL_PAYPAL_LINKS=true
WEB_ENABLE_PAYPAL_LINKS=true

# Client mirror of platform visibility (no secrets)
VITE_PAYPAL_CHECKOUT_ENABLED=false
VITE_WEB_ENABLE_PAYPAL_LINKS=true
VITE_IOS_HIDE_EXTERNAL_PAYPAL_LINKS=true
VITE_ANDROID_HIDE_EXTERNAL_PAYPAL_LINKS=true

# Plan limits
PLAN_FREE_SHORT_AI_LIMIT=3
PLAN_PRO_SHORT_AI_LIMIT=30
PLAN_MASTER_SHORT_AI_LIMIT=100

PLAN_PRO_PREMIUM_REPORT_LIMIT=2
PLAN_MASTER_PREMIUM_REPORT_LIMIT=8

PLAN_PRO_CHAT_LIMIT=30
PLAN_MASTER_CHAT_LIMIT=150

# PWA
VITE_PWA_ENABLED=true
VITE_PWA_LOW_PERFORMANCE_AUTO=true
